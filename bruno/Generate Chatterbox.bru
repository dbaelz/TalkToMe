meta {
  name: Generate Chatterbox
  type: http
  seq: 3
}

post {
  url: {{host}}/tts
  body: json
  auth: basic
}

auth:basic {
  username: {{auth_username}}
  password: {{auth_password}}
}

body:json {
  {
    "text": "Hello listener, how are you?",
    "config": {
      "exaggeration": 0.5
    },
    "engine": "CHATTERBOX"
  }
}
